alias smrekca='(clear; trap "tput cnorm; clear; exit" INT TERM; tput civis; tree=( "          *" "         /***" "        /*****" "       /*******" "      /*********" "     /***********" "    /*************" "         |||" "         |||" ); colors=(31 32 33 34 35 36); while true; do clear; for line in "${tree[@]}"; do c=${colors[$RANDOM % ${#colors[@]}]}; printf "\e[%sm%s\e[0m\n" "$c" "$line"; done; echo; printf "\e[1;32m     Vesel božič!\e[0m\n"; sleep 0.5; done)'

# --- Skripte za čiščenje in varnost ---
cleanoldkernels() { current=$(uname -r | sed "s/-.*//"); kernels=($(eopkg list-installed | awk '/^linux-/{print $1}' | sort -V -r)); active=""; for k in "${kernels[@]}"; do ver=${k#linux-}; [[ "$current" == "$ver"* ]] && { active=$k; break; }; done; [[ -z "$active" ]] && return; [[ "${kernels[0]}" == "$active" ]] && penultimate=${kernels[1]} || penultimate=${kernels[0]}; for k in "${kernels[@]}"; do [[ "$k" != "$active" && "$k" != "$penultimate" ]] && sudo eopkg remove -y "$k"; done; }

# --- Omrežje / firewall helper ---
fwop() {
  echo "fwop: začnem"
  if ! command -v ufw >/dev/null 2>&1; then
    echo "fwop: napaka"
    return 1
  fi
  primary="${1:-$(ip -o -4 addr show scope global | awk '{print $4; exit}')}"
  if [ -z "$primary" ]; then
    echo "fwop: napaka"
    return 1
  fi
  net=""
  if command -v python3 >/dev/null 2>&1; then
    net=$(python3 - <<PY 2>/dev/null
import sys, ipaddress
try:
    print(ipaddress.ip_network(sys.argv[1], False).with_prefixlen)
except Exception:
    sys.exit(1)
PY
"$primary" 2>/dev/null) || net=""
  fi
  if [ -z "$net" ]; then
    IFS='/' read -r ip mask <<< "$primary"
    if [ "$mask" = "24" ]; then
      net="${ip%.*}.0/24"
    else
      net="$primary"
    fi
  fi
  add_if_missing() {
    local check="$1"; shift
    if sudo ufw status --no-reload 2>/dev/null | sed 's/\s\+/ /g' | grep -Fqi "$check"; then
      return 0
    fi
    sudo ufw "$@" >/dev/null 2>&1
  }
  checks=( \
    "53" \
    "67" \
    "from $net to any port 1714:1764 proto udp" \
    "from $net to any port 1714:1764 proto tcp" \
    "from $net to any port 5353 proto udp" \
  )
  cmds=( \
    "allow 53" \
    "allow 67" \
    "allow proto udp from $net to any port 1714:1764" \
    "allow proto tcp from $net to any port 1714:1764" \
    "allow proto udp from $net to any port 5353" \
  )
  for i in "${!cmds[@]}"; do
    cmd="${cmds[$i]}"
    set -- $cmd
    if ! add_if_missing "${checks[$i]}" "$@"; then
      echo "fwop: napaka"
      return 1
    fi
  done
  if ! sudo ufw default allow FORWARD >/dev/null 2>&1; then
    echo "fwop: napaka"
    return 1
  fi
  if sudo ufw status 2>/dev/null | head -n1 | grep -qi inactive; then
    if ! sudo ufw --force enable >/dev/null 2>&1; then
      echo "fwop: napaka"
      return 1
    fi
  fi
  echo "fwop: končano"
}

# --- Interaktivni startup (le če ni container / ne-VSCode) ---
is_in_dolphin() {
  p=$$
  while [ "$p" -ne 1 ] 2>/dev/null; do
    p=$(ps -o ppid= -p "$p" | tr -d ' ')
    [ -z "$p" ] && break
    cmd=$(ps -o comm= -p "$p" | tr -d ' ')
    case "$cmd" in
      dolphin|dolphin-ephemeral) return 0 ;;
    esac
  done
  return 1
}

is_in_zed() {
  case "${TERM_PROGRAM:-}" in *zed*|*Zed*) return 0;; esac
  env | grep -qi '^ZED' && return 0

  pid=$$
  while [ -n "$pid" ] && [ "$pid" -ne 1 ]; do
    ps -o comm= -p "$pid" 2>/dev/null | grep -qi zed && return 0
    pid=$(ps -o ppid= -p "$pid" 2>/dev/null | tr -d ' ' || true)
  done

  return 1
}

# primer uporabe
if [ -z "$CONTAINER_ID" ] && [ "$TERM_PROGRAM" != "vscode" ]; then
  if ! is_in_dolphin && ! is_in_zed; then
    command -v neofetch >/dev/null 2>&1 && neofetch
  fi
fi

# Starship in rust env
eval "$(starship init bash)"
. "$HOME/.cargo/env"

# Copilot alias/function "c" - pass remaining words as single string to copilot CLI
c() {
  if command -v copilot >/dev/null 2>&1; then
    output="$(copilot -p "$*" 2>&1)"
    ret=$?
    printf '%s\n' "$output" | sed '/^Total usage est:/,$d'
    return $ret
  elif command -v gh >/dev/null 2>&1 && gh --help | grep -q "copilot"; then
    output="$(gh copilot -p "$*" 2>&1)"
    ret=$?
    printf '%s\n' "$output" | sed '/^Total usage est:/,$d'
    return $ret
  else
    echo "No copilot CLI found. Install GitHub Copilot CLI or enable the GitHub CLI copilot extension."
  fi
}
#
# Funkciji za nastavljanje lokalizacije (z source /etc/locale.conf na koncu)
fixlocale() {
    sudo tee /etc/locale.conf >/dev/null <<EOF
LANG=sl_SI.UTF-8
LC_ADDRESS=sl_SI.UTF-8
LC_IDENTIFICATION=sl_SI.UTF-8
LC_MEASUREMENT=sl_SI.UTF-8
LC_MONETARY=sl_SI.UTF-8
LC_NAME=sl_SI.UTF-8
LC_NUMERIC=sl_SI.UTF-8
LC_PAPER=sl_SI.UTF-8
LC_TELEPHONE=sl_SI.UTF-8
LC_TIME=sl_SI.UTF-8
EOF

    sudo tee /etc/default/locale >/dev/null <<'EOF'
LANG="sl_SI.UTF-8"
LC_ADDRESS="sl_SI.UTF-8"
LC_IDENTIFICATION="sl_SI.UTF-8"
LC_MEASUREMENT="sl_SI.UTF-8"
LC_MONETARY="sl_SI.UTF-8"
LC_NAME="sl_SI.UTF-8"
LC_NUMERIC="sl_SI.UTF-8"
LC_PAPER="sl_SI.UTF-8"
LC_TELEPHONE="sl_SI.UTF-8"
LC_TIME="sl_SI.UTF-8"
EOF

    echo "Locale nastavljena na sl_SI.UTF-8 (zapisano v /etc/locale.conf in /etc/default/locale)"
    source /etc/locale.conf 2>/dev/null || true
}

unfixlocale() {
    sudo tee /etc/locale.conf >/dev/null <<EOF
LANG=sl_SI.utf8
LC_ADDRESS=sl_SI.utf8
LC_IDENTIFICATION=sl_SI.utf8
LC_MEASUREMENT=sl_SI.utf8
LC_MONETARY=sl_SI.utf8
LC_NAME=sl_SI.utf8
LC_NUMERIC=sl_SI.utf8
LC_PAPER=sl_SI.utf8
LC_TELEPHONE=sl_SI.utf8
LC_TIME=sl_SI.utf8
EOF

    sudo tee /etc/default/locale >/dev/null <<'EOF'
LANG="sl_SI.utf8"
LC_ADDRESS="sl_SI.utf8"
LC_IDENTIFICATION="sl_SI.utf8"
LC_MEASUREMENT="sl_SI.utf8"
LC_MONETARY="sl_SI.utf8"
LC_NAME="sl_SI.utf8"
LC_NUMERIC="sl_SI.utf8"
LC_PAPER="sl_SI.utf8"
LC_TELEPHONE="sl_SI.utf8"
LC_TIME="sl_SI.utf8"
EOF

    echo "Locale nastavljena na sl_SI.utf8 (zapisano v /etc/locale.conf in /etc/default/locale — lahko ni vedno kompatibilno)"
    source /etc/locale.conf 2>/dev/null || true
    locale
}
